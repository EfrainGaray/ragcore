# ragcore — copy this file to .env and fill in your values
# All variables are optional; defaults are shown.

# ── Vector Store ──────────────────────────────────────────────────────────────
CHROMA_PATH=./data/chroma
CHROMA_COLLECTION=ragcore
CHROMA_NAMESPACE=default

# ── Retrieval ─────────────────────────────────────────────────────────────────
TOP_K=10
TOP_N=5

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
MCP_PORT=8001

# ── Embedding Provider ────────────────────────────────────────────────────────
# "local" = sentence-transformers (offline, no key)
# "openai" = any /v1/embeddings API
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=all-MiniLM-L6-v2
# EMBEDDING_API_URL=huggingface   # aliases: openai · huggingface · nvidia · together · groq · ollama
# EMBEDDING_API_KEY=hf_xxxxxxxxxxxx

# ── Reranker Provider ─────────────────────────────────────────────────────────
# "local" = CrossEncoder (offline, no key)
# "cohere" / "jina" / "voyage" = remote /v1/rerank API
RERANK_PROVIDER=local
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-2-v2
# RERANK_PROVIDER=cohere
# RERANK_API_KEY=your-cohere-key
# RERANK_MODEL=rerank-v3.5
